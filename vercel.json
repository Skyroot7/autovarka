{
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "regions": ["fra1"],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.autovarka.com.ua"
        }
      ],
      "destination": "https://autovarka.com.ua/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "m.autovarka.com.ua"
        }
      ],
      "destination": "https://autovarka.com.ua/:path*",
      "permanent": true
    }
  ]
}
